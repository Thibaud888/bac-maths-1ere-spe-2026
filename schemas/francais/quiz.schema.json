{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "quiz.schema.json",
  "title": "Quiz / Repère (Français)",
  "description": "Question rapide de repérage (identifier un procédé, dater un mouvement, reconnaître un registre, ordonner les étapes d'une méthode). Trois types : qcm (1 bonne réponse), multi (plusieurs bonnes réponses), ordering (remettre dans l'ordre).",
  "type": "object",
  "required": ["id", "category", "type", "statement", "explanation", "difficulty"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^qz-[a-z0-9-]+$",
      "description": "Identifiant unique. Format : qz-<slug>. Ex : qz-figure-anaphore"
    },
    "module": {
      "type": "string",
      "enum": [
        "methode-commentaire",
        "methode-dissertation",
        "figures-de-style",
        "mouvements-litteraires",
        "registres-genres",
        "poesie",
        "litterature-idees",
        "roman",
        "theatre",
        "transverse"
      ],
      "description": "Module rattaché. 'transverse' pour les repères non spécifiques."
    },
    "category": {
      "type": "string",
      "enum": ["figures", "mouvements", "registres", "genres", "methode", "culture"],
      "description": "Domaine de repérage."
    },
    "type": {
      "type": "string",
      "enum": ["qcm", "multi", "ordering"],
      "description": "qcm = un seul choix correct ; multi = plusieurs choix corrects à cocher ; ordering = remettre les éléments dans l'ordre attendu."
    },
    "statement": {
      "type": "string",
      "minLength": 5,
      "description": "Énoncé / consigne. Markdown enrichi."
    },
    "choices": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 6,
      "description": "Choix proposés (types qcm et multi)."
    },
    "answer": {
      "type": "integer",
      "minimum": 0,
      "description": "Index (0-based) de la bonne réponse (type qcm)."
    },
    "answers": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 1,
      "description": "Index (0-based) des bonnes réponses (type multi)."
    },
    "items": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 8,
      "description": "Éléments donnés DANS L'ORDRE ATTENDU (type ordering). Ils seront mélangés à l'affichage."
    },
    "explanation": {
      "type": "string",
      "minLength": 5,
      "description": "Explication courte après réponse. Markdown."
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "timeLimitSeconds": {
      "type": "integer",
      "minimum": 15,
      "maximum": 180,
      "default": 60
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "qcm" } } },
      "then": { "required": ["choices", "answer"] }
    },
    {
      "if": { "properties": { "type": { "const": "multi" } } },
      "then": { "required": ["choices", "answers"] }
    },
    {
      "if": { "properties": { "type": { "const": "ordering" } } },
      "then": { "required": ["items"] }
    }
  ]
}
