{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "classic-exercise.schema.json",
  "title": "Classic Exercise",
  "description": "Exercice d'application directe d'une notion du cours, avec correction progressive (3 niveaux d'aide).",
  "type": "object",
  "required": ["id", "chapter", "title", "difficulty", "estimatedMinutes", "questions"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^c-[a-z0-9-]+$",
      "description": "Identifiant. Format: c-<chapitre>-<num3>. Ex: c-suites-001"
    },
    "chapter": {
      "type": "string",
      "enum": [
        "suites",
        "second-degre",
        "derivation",
        "exponentielle",
        "trigonometrie",
        "produit-scalaire",
        "geometrie-reperee",
        "probas-cond",
        "variables-aleatoires"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "description": "Titre court de l'exercice"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "description": "1 = très simple ; 2 = niveau standard ; 3 = exigeant pour première"
    },
    "estimatedMinutes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30,
      "description": "Durée estimée pour résoudre l'exercice"
    },
    "prerequisites": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Notions ou chapitres prérequis (slugs ou descriptions courtes)"
    },
    "preamble": {
      "type": "string",
      "description": "Énoncé d'introduction commun à toutes les questions. Markdown + LaTeX."
    },
    "figure": {"$ref": "figure.schema.json"},
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "statement", "hints", "solution"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^q[0-9]+[a-z]?$",
            "description": "Ex: q1, q2, q3a"
          },
          "label": {
            "type": "string",
            "description": "Libellé court affiché. Ex: '1.', '2.a)', '3.'"
          },
          "statement": {
            "type": "string",
            "minLength": 3
          },
          "hints": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "maxItems": 3,
            "description": "Aides progressives. [0] = indice de méthode, [1] = étape-par-étape, [2] = solution résumée. La solution complète est dans 'solution'."
          },
          "expectedAnswer": {
            "type": "string",
            "description": "Réponse attendue, sous forme courte (LaTeX). Optionnel."
          },
          "solution": {
            "type": "string",
            "minLength": 10,
            "description": "Correction rédigée complète, en Markdown + LaTeX. Doit suivre les conventions de rédaction du bac (justifications, 'donc', 'or', 'ainsi')."
          },
          "figure": {"$ref": "figure.schema.json"}
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "order": {
      "type": "integer",
      "minimum": 0,
      "description": "Ordre dans la liste du chapitre (généralement par difficulté croissante)"
    }
  }
}
